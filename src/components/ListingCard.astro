---
// Shared listing card used in grid views on both JWRG and JWLC.
//
// `headline` is the small text under the county pill — JWRG passes
// beds/baths/sqft; JWLC passes acreage. Each site's local
// `src/components/ListingCard.astro` is a tiny wrapper that computes its
// preferred headline and forwards everything else here.
//
// CSS classes referenced (`listing-card*`) live in @jw/shared/styles/listings.css,
// imported by each site's global.css.
//
// Markup is an <article> (display:contents so it adds no box) wrapping the
// clickable <a>, giving agents/crawlers a stable extraction anchor. The image
// is a <picture> emitting avif/webp/jpg with responsive srcset + intrinsic
// dimensions (no layout shift); price is a <data> with the numeric value.

import type { ApiListing } from '@jw/shared/api';
import { formatPrice, photoSrc, photoSrcSet, photoDimensions, photoAlt } from '@jw/shared/api';

interface Props {
  listing: ApiListing;
  index?: number;
  headline?: string;
}

const { listing, headline } = Astro.props;
const title = listing.marketing_title || listing.address;
const photo = listing.primary_photo;
const image = photoSrc(photo, 800);
const dims = photoDimensions(photo, 800);
const avif = photoSrcSet(photo, 'avif');
const webp = photoSrcSet(photo, 'webp');
const jpg = photoSrcSet(photo, 'jpg');
const alt = photoAlt(photo, listing.address);
const headlineText = headline || `${listing.city}, ${listing.state}`;
// Cards render one-per-column on mobile, two at sm, three at lg.
const sizes = '(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw';
const priceValue = parseFloat(listing.list_price);
---

<article class="[display:contents]">
<a href={`/listings/${listing.slug}`} class="listing-card">
  <!-- Image Header -->
  <div class="listing-card-image">
    {image ? (
      <picture>
        {avif && <source type="image/avif" srcset={avif} sizes={sizes} />}
        {webp && <source type="image/webp" srcset={webp} sizes={sizes} />}
        <img
          src={image}
          srcset={jpg ?? undefined}
          sizes={jpg ? sizes : undefined}
          width={dims?.width}
          height={dims?.height}
          alt={alt}
          class="listing-card-img"
          loading="lazy"
          decoding="async"
        />
      </picture>
    ) : (
      <div class="listing-card-img listing-card-img--placeholder"></div>
    )}
    <div class="listing-card-gradient"></div>
    <div class="listing-card-overlay">
      <div>
        <address class="listing-card-county not-italic">{listing.county} County</address>
        <p class="listing-card-acreage">{headlineText}</p>
      </div>
    </div>
    {listing.photo_count > 1 && (
      <span class="listing-card-photos-badge" aria-label={`${listing.photo_count} photos`}>
        <svg class="listing-card-photos-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.41a2.25 2.25 0 013.182 0l2.909 2.91M3.75 21h16.5a2.25 2.25 0 002.25-2.25V5.25a2.25 2.25 0 00-2.25-2.25H3.75a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 003.75 21z" />
        </svg>
        <span aria-hidden="true">{listing.photo_count}</span>
      </span>
    )}
    <span class="listing-card-status" data-status={listing.status}>
      {listing.status_label}
    </span>
  </div>

  <!-- Content -->
  <div class="listing-card-body">
    <h3 class="listing-card-title">{title}</h3>
    <p class="listing-card-desc">{listing.description}</p>
    <div class="listing-card-footer">
      <data class="listing-card-price" value={Number.isNaN(priceValue) ? undefined : String(priceValue)}>{formatPrice(listing.list_price)}</data>
      <span class="listing-card-link">
        View Details
        <svg class="listing-card-link-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </span>
    </div>
  </div>
</a>
</article>

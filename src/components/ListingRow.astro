---
// Shared listing row used in list views on both JWRG and JWLC.
//
// `headline` is the right-side text above price — JWRG passes
// beds/baths/sqft; JWLC passes acreage. Each site's local
// `src/components/ListingRow.astro` is a tiny wrapper that computes the
// site-appropriate headline and forwards listing through.
//
// CSS classes referenced (`listing-row*`) live in @jw/shared/styles/listings.css,
// imported by each site's global.css.
//
// Markup mirrors ListingCard: an <article> (display:contents) wrapping the
// clickable <a>, a <picture> thumbnail with avif/webp/jpg + intrinsic dims,
// the county in <address>, and the price in <data>.

import type { ApiListing } from '@jw/shared/api';
import { formatPrice, photoSrc, photoSrcSet, photoDimensions, photoAlt } from '@jw/shared/api';

interface Props {
  listing: ApiListing;
  headline?: string;
}

const { listing, headline } = Astro.props;
const title = listing.marketing_title || listing.address;
const photo = listing.primary_photo;
const image = photoSrc(photo, 800);
const dims = photoDimensions(photo, 800);
const avif = photoSrcSet(photo, 'avif');
const webp = photoSrcSet(photo, 'webp');
const jpg = photoSrcSet(photo, 'jpg');
const alt = photoAlt(photo, listing.address);
const headlineText = headline ?? '';
// The thumbnail is a small fixed-ish column on the left of the row.
const sizes = '(min-width: 640px) 16rem, 40vw';
const priceValue = parseFloat(listing.list_price);
---

<article class="[display:contents]">
<a href={`/listings/${listing.slug}`} class="listing-row">
  <!-- Thumbnail -->
  <div class="listing-row-thumb">
    {image ? (
      <picture>
        {avif && <source type="image/avif" srcset={avif} sizes={sizes} />}
        {webp && <source type="image/webp" srcset={webp} sizes={sizes} />}
        <img
          src={image}
          srcset={jpg ?? undefined}
          sizes={jpg ? sizes : undefined}
          width={dims?.width}
          height={dims?.height}
          alt={alt}
          class="listing-row-img"
          loading="lazy"
          decoding="async"
        />
      </picture>
    ) : (
      <div class="listing-row-img listing-row-img--placeholder"></div>
    )}
  </div>

  <!-- Content area (everything right of thumb) -->
  <div class="listing-row-content">
    <!-- Main info -->
    <div class="listing-row-body">
      <div class="listing-row-meta">
        <span class="listing-row-status" data-status={listing.status}>
          {listing.status_label}
        </span>
        <address class="listing-row-county not-italic">{listing.county} County</address>
      </div>
      <h3 class="listing-row-title">{title}</h3>
    </div>

    <!-- Price + link -->
    <div class="listing-row-right">
      <p class="listing-row-acreage">{headlineText}</p>
      <data class="listing-row-price" value={Number.isNaN(priceValue) ? undefined : String(priceValue)}>{formatPrice(listing.list_price)}</data>
      <span class="listing-row-link">
        View Details
        <svg class="listing-row-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </span>
    </div>
  </div>
</a>
</article>
